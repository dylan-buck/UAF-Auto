# Gateway listener. Keep this localhost-only and expose it with Cloudflare Tunnel + Access.
MCP_HOST=127.0.0.1
MCP_PORT=8787
# Add the public Cloudflare hostname here too, or configure cloudflared httpHostHeader=localhost.
MCP_ALLOWED_HOSTS=127.0.0.1,localhost,mcp.company.com

# Optional bearer secret for local/direct MCP access. Cloudflare Access should be the primary public auth layer.
MCP_SHARED_SECRET=change-me-long-random-value

# Existing UAFMiddleware URL on the Sage server.
UAF_SAGE_API_URL=http://localhost:3000

# Prefer separate upstream API keys by scope.
UAF_SAGE_READ_API_KEY=read-key-from-middleware
UAF_SAGE_CREATE_API_KEY=create-key-from-middleware
UAF_SAGE_FINANCE_API_KEY=finance-key-from-middleware

# Finance and create tools are hidden unless explicitly enabled.
ENABLE_FINANCE_TOOLS=false
ENABLE_CREATE_TOOLS=false

# Readiness check timeout in milliseconds.
UAF_SAGE_TIMEOUT_MS=30000
